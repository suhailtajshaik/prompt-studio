{
  "name": "prompt-studio",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "docker:build": "docker build -t suhailtaj/prompt-studio:latest .",
    "docker:run": "docker run -d --name prompt-studio -p 3000:80 suhailtaj/prompt-studio:latest",
    "docker:push": "docker push suhailtaj/prompt-studio:latest",
    "docker:build-push": "npm run docker:build && npm run docker:push",
    "docker:stop": "docker stop prompt-studio && docker rm prompt-studio",
    "docker:clean": "docker stop prompt-studio 2>/dev/null; docker rm prompt-studio 2>/dev/null; docker rmi suhailtaj/prompt-studio:latest 2>/dev/null; echo 'Cleaned up'",
    "compose:up": "docker compose up --build -d",
    "compose:up:gpu": "docker compose --profile gpu up --build -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "compose:clean": "docker compose down -v"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.12.0",
    "lucide-react": "^0.460.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^6.0.3"
  }
}
